# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Deepgram (transcription)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Anthropic (AI analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model overrides. Defaults are current Claude API model IDs.
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001

# OpenAI (roleplay realtime voice)
OPENAI_API_KEY=your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-realtime

# Internal recovery/split workers
INTERNAL_API_SECRET=generate-a-32-char-random-secret
CRON_SECRET=generate-a-different-32-char-random-secret

# Platform admins who can create separate customer teams
PLATFORM_ADMIN_EMAILS=owner@example.com
